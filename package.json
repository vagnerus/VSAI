{
  "name": "nexus-ai",
  "version": "1.0.0",
  "description": "VSAI - IA — Plataforma de IA Completa com Painel Web",
  "type": "module",
  "main": "src/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "node --watch src/server/index.js",
    "dev:client": "vite",
    "build": "vite build",
    "start": "node src/server/index.js",
    "start:prod": "NODE_ENV=production node src/server/index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs --env production",
    "pm2:stop": "pm2 stop nexus-server",
    "pm2:restart": "pm2 restart nexus-server",
    "pm2:logs": "pm2 logs nexus-server",
    "dist": "npm run build && electron-builder",
    "electron:dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"wait-on http://localhost:5173 && electron .\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@react-three/drei": "^9.117.3",
    "@react-three/fiber": "^8.17.10",
    "@supabase/supabase-js": "^2.49.0",
    "@vercel/speed-insights": "^1.3.1",
    "bcryptjs": "^2.4.3",
    "concurrently": "^9.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "electron-is-dev": "^3.0.1",
    "express": "^4.21.1",
    "framer-motion": "^11.11.17",
    "jose": "^5.9.0",
    "lucide-react": "^0.446.0",
    "marked": "^15.0.4",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.5",
    "recharts": "^2.15.1",
    "stripe": "^15.12.0",
    "three": "^0.170.0",
    "uuid": "^14.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.19",
    "electron": "^41.4.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.1",
    "vite": "^6.0.5",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.vsai.ia",
    "productName": "VSAI - IA",
    "directories": {
      "output": "dist_electron"
    },
    "win": {
      "target": "portable",
      "icon": "public/icon.ico"
    },
    "files": [
      "dist/**/*",
      "src/server/**/*",
      "src/engine/**/*",
      "src/tools/**/*",
      "src/session/**/*",
      "src/permissions/**/*",
      "src/hooks/**/*",
      "src/api/**/*",
      "src/main/**/*",
      "data/**/*",
      "package.json",
      "nexus.config.json",
      ".env"
    ],
    "asar": true
  }
}
