{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/painel", "destination": "/painel.html" },
    { "source": "/((?!api|assets|painel).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/chat.js": { "maxDuration": 60 },
    "api/**/*.js": { "maxDuration": 10 }
  }
}
