# ============================================================
#  NexusAI — Environment Configuration Template
#  Copie para .env e preencha suas chaves reais
# ============================================================

DEFAULT_PROVIDER=gemini

GEMINI_API_KEY=
ANTHROPIC_API_KEY=

GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_MODEL=claude-sonnet-4-20250514

PORT=3777
NODE_ENV=development
CORS_ORIGIN=*

SESSION_STORAGE_PATH=./data/sessions
DATABASE_PATH=./data/nexus.db
USE_DATABASE=false

MAX_TOKENS=8192
DEBUG=false
